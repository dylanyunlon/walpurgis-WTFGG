# ──────────────────────────────────────────────────────────────────────────────
# 1. SharedWorkflowRefKind — 引用策略枚举
#    上游隐藏在 @cuda-13.1.0 vs @main 字符串差异里，此处显式枚举。
# ──────────────────────────────────────────────────────────────────────────────
class SharedWorkflowRefKind(Enum):
    """CI shared-workflow 引用策略类型。"""
    PINNED  = "pinned"   # 固定版本标签，如 @cuda-13.1.0；稳定但滞后
    ROLLING = "rolling"  # 滚动主干分支，如 @main；实时但有漂移风险

    def is_stable(self) -> bool:
        """固定引用：可重现但不跟踪上游改进。"""
        return self is SharedWorkflowRefKind.PINNED

    def is_live(self) -> bool:
        """滚动引用：实时跟踪，与上游同呼吸。"""
        return self is SharedWorkflowRefKind.ROLLING

    def label(self) -> str:
        """人类可读标签。"""
        return {
            SharedWorkflowRefKind.PINNED:  "固定版本标签（钉死的时间切片）",
            SharedWorkflowRefKind.ROLLING: "滚动主干分支（追着 main 走）",
        }[self]


_dbg("enum_init", f"SharedWorkflowRefKind 枚举已构造：{[e.name for e in SharedWorkflowRefKind]}")


# ──────────────────────────────────────────────────────────────────────────────
# 2. SharedWorkflowRef — 单条 uses 引用的结构化表示
#    上游：散落在 YAML 中的字符串字面量 `repo/path/workflow.yaml@ref`
#    此处：具名对象，携带 repo、workflow_path、kind、ref_value 四元组
# ──────────────────────────────────────────────────────────────────────────────
@dataclass(frozen=True)
class SharedWorkflowRef:
    """一条 `uses:` 引用的完整语义描述。"""
    repo:          str                  # 如 rapidsai/shared-workflows
    workflow_path: str                  # 如 .github/workflows/conda-cpp-build.yaml
    kind:          SharedWorkflowRefKind
    ref_value:     str                  # 如 main 或 cuda-13.1.0
    host_workflow: str                  # 本仓库中哪个 workflow 文件持有此引用

    def uses_string(self) -> str:
        """还原上游 YAML `uses:` 字段的完整值。"""
        return f"{self.repo}/{self.workflow_path}@{self.ref_value}"

    def audit_line(self) -> str:
        """产出可嵌入 YAML 注释的单行审计字符串。"""
        return (
            f"# [walpurgis-audit] {self.host_workflow} → "
            f"{self.workflow_path}@{self.ref_value} "
            f"({self.kind.name})"
        )

    def __str__(self) -> str:
        return f"SharedWorkflowRef({self.workflow_path}@{self.ref_value}, {self.kind.name})"


# ──────────────────────────────────────────────────────────────────────────────
# 3. WorkflowMigrationRecord — 单次分支策略切换的审计记录
#    上游：此信息完全散落在 git log 里，开发者只能 `git log --oneline` 推算
#    此处：可审计的结构化记录，summary() / audit_line() 双出口
# ──────────────────────────────────────────────────────────────────────────────
@dataclass(frozen=True)
class WorkflowMigrationRecord:
    """一次 shared-workflows 分支策略切换的完整审计记录。"""
    commit_sha:     str
    pr_url:         str
    from_ref:       str   # 切换前的引用标签，如 cuda-13.1.0
    to_ref:         str   # 切换后的引用标签，如 main
    workflow_count: int   # 本次切换涉及的 uses 引用条数（上游：30 处）
    affected_files: List[str]  # 受影响的宿主 workflow 文件列表

    def summary(self) -> str:
        """单行摘要；用于日志输出或 MIGRATION_LOG 条目。"""
        return (
            f"[{self.commit_sha[:7]}] shared-workflows "
            f"@{self.from_ref} → @{self.to_ref}，"
            f"涉及 {self.workflow_count} 处引用，"
            f"{len(self.affected_files)} 个 workflow 文件"
        )

    def audit_line(self) -> str:
        """产出可嵌入 YAML 注释的审计字符串（多行）。"""
        files = ", ".join(self.affected_files)
        return (
            f"# [walpurgis-migration] commit={self.commit_sha[:7]} "
            f"pr={self.pr_url}\n"
            f"#   @{self.from_ref} → @{self.to_ref} "
            f"({self.workflow_count} refs in [{files}])"
        )

    def __post_init__(self) -> None:
        _dbg("record_init", f"WorkflowMigrationRecord 构造：{self.summary()}")
        if self.workflow_count <= 0:
            raise ValueError("workflow_count 必须 > 0")
        if not self.commit_sha:
            raise ValueError("commit_sha 不能为空")


# ──────────────────────────────────────────────────────────────────────────────
# 4. SharedWorkflowBranchManifest — 全量引用清单（Single Source of Truth）
#    上游：30 处相同字符串字面量散落在 4 个 YAML 文件的 uses 字段里
#    此处：单点定义，rolling_ratio() / audit_report() 双出口
# ──────────────────────────────────────────────────────────────────────────────
class SharedWorkflowBranchManifest:
    """
    rapidsai/cugraph-gnn 所有 shared-workflows 引用的完整清单。

    对应上游 commit 2910605（PR #385）切换后的状态：
    全部 30 处引用均已从 @cuda-13.1.0 迁移至 @main。

    上游只有散落在 YAML 里的字面量，此处提供：
      - all_refs()      枚举全部引用
      - rolling_ratio() 计算滚动引用占比（用于 CI 健康度审计）
      - audit_report()  产出结构化审计报告
    """

    _REPO = "rapidsai/shared-workflows"

    # 上游迁移记录（commit 2910605）
    MIGRATION = WorkflowMigrationRecord(
        commit_sha     = "2910605",
        pr_url         = "https://github.com/rapidsai/cugraph-gnn/pull/385",
        from_ref       = "cuda-13.1.0",
        to_ref         = "main",
        workflow_count = 30,
        affected_files = [
            ".github/workflows/build.yaml",
            ".github/workflows/pr.yaml",
            ".github/workflows/test.yaml",
            ".github/workflows/trigger-breaking-change-alert.yaml",
        ],
    )

    # 当前状态：切换后全部为 ROLLING
    _REFS: List[SharedWorkflowRef] = []

    # build.yaml 中的 10 条引用
    _BUILD_WORKFLOWS = [
        "conda-cpp-build.yaml",
        "conda-python-build.yaml",
        "custom-job.yaml",
        "conda-upload-packages.yaml",
        "wheels-build.yaml",       # cugraph-pyg
        "wheels-publish.yaml",     # cugraph-pyg
        "wheels-build.yaml",       # libwholegraph
        "wheels-build.yaml",       # pylibwholegraph
        "wheels-publish.yaml",     # libwholegraph
        "wheels-publish.yaml",     # pylibwholegraph
    ]

    def __init__(self) -> None:
        _dbg("manifest_init", "SharedWorkflowBranchManifest 开始构造")
        self._refs: List[SharedWorkflowRef] = []
        self._build_refs()
        _dbg("manifest_init", f"manifest 构造完成，共 {len(self._refs)} 条引用")

    def _build_refs(self) -> None:
        """从已知上游文件构造引用清单（切换后状态：全部 ROLLING/main）。"""
        _dbg("build_refs", "开始构造引用清单")

        # build.yaml — 10 条引用
        for wf in self._BUILD_WORKFLOWS:
            self._refs.append(SharedWorkflowRef(
                repo          = self._REPO,
                workflow_path = f".github/workflows/{wf}",
                kind          = SharedWorkflowRefKind.ROLLING,
                ref_value     = "main",
                host_workflow = ".github/workflows/build.yaml",
            ))

        # pr.yaml — 约 15 条引用（含 pr-builder + changed-files + CI matrix）
        PR_WORKFLOWS = [
            "pr-builder.yaml", "changed-files.yaml",
            "conda-cpp-build.yaml", "conda-python-build.yaml",
            "conda-cpp-tests.yaml", "conda-notebook-tests.yaml",
            "conda-python-tests.yaml", "custom-job.yaml",
            "wheels-build.yaml", "wheels-tests-dgl.yaml",
            "wheels-tests-pyg.yaml", "wheels-build.yaml",
            "wheels-tests-cugraph-pyg.yaml", "wheels-tests-dgl.yaml",
            "wheels-tests-pyg.yaml",
        ]
        for wf in PR_WORKFLOWS:
            self._refs.append(SharedWorkflowRef(
                repo          = self._REPO,
                workflow_path = f".github/workflows/{wf}",
                kind          = SharedWorkflowRefKind.ROLLING,
                ref_value     = "main",
                host_workflow = ".github/workflows/pr.yaml",
            ))

        # test.yaml — 4 条引用
        TEST_WORKFLOWS = [
            "conda-cpp-tests.yaml", "conda-notebook-tests.yaml",
            "conda-python-tests.yaml", "custom-job.yaml",
        ]
        for wf in TEST_WORKFLOWS:
            self._refs.append(SharedWorkflowRef(
                repo          = self._REPO,
                workflow_path = f".github/workflows/{wf}",
                kind          = SharedWorkflowRefKind.ROLLING,
                ref_value     = "main",
                host_workflow = ".github/workflows/test.yaml",
            ))

        # trigger-breaking-change-alert.yaml — 1 条引用
        self._refs.append(SharedWorkflowRef(
            repo          = self._REPO,
            workflow_path = ".github/workflows/trigger-breaking-change-alert.yaml",
            kind          = SharedWorkflowRefKind.ROLLING,
            ref_value     = "main",
            host_workflow = ".github/workflows/trigger-breaking-change-alert.yaml",
        ))

        _dbg("build_refs", f"引用清单构造完成，共 {len(self._refs)} 条")

    def all_refs(self) -> List[SharedWorkflowRef]:
        """枚举全部 shared-workflow 引用（切换后状态）。"""
        return list(self._refs)

    def rolling_ratio(self) -> float:
        """计算滚动引用（@main）占比；=1.0 表示全部已切换。"""
        if not self._refs:
            return 0.0
        rolling = sum(1 for r in self._refs if r.kind.is_live())
        ratio = rolling / len(self._refs)
        _dbg("rolling_ratio", f"rolling={rolling}/{len(self._refs)}, ratio={ratio:.2%}")
        return ratio

    def refs_by_host(self, host_workflow: str) -> List[SharedWorkflowRef]:
        """按宿主 workflow 文件筛选引用。"""
        _dbg("refs_by_host", f"筛选 host_workflow={host_workflow}")
        return [r for r in self._refs if r.host_workflow == host_workflow]

    def audit_report(self) -> str:
        """产出结构化审计报告；覆盖迁移元数据 + 引用统计 + 健康度。"""
        _dbg("audit_report", "开始生成审计报告")
        rolling = sum(1 for r in self._refs if r.kind.is_live())
        pinned  = len(self._refs) - rolling
        hosts   = sorted(set(r.host_workflow for r in self._refs))

        lines = [
            "═" * 60,
            "  SharedWorkflowBranchManifest 审计报告",
            "═" * 60,
            f"  迁移 commit : {self.MIGRATION.commit_sha[:7]}",
            f"  PR          : {self.MIGRATION.pr_url}",
            f"  切换策略    : @{self.MIGRATION.from_ref} → @{self.MIGRATION.to_ref}",
            f"  总引用数    : {len(self._refs)}",
            f"  ROLLING     : {rolling}  （滚动主干，追着 main 走）",
            f"  PINNED      : {pinned}   （固定标签，钉死的时间切片）",
            f"  滚动占比    : {self.rolling_ratio():.1%}",
            f"  受影响文件  : {len(hosts)} 个",
        ]
        for h in hosts:
            count = len(self.refs_by_host(h))
            lines.append(f"    • {h} ({count} refs)")
        lines.append("═" * 60)

        report = "\n".join(lines)
        _dbg("audit_report", f"审计报告生成完成，{len(lines)} 行")
        return report


