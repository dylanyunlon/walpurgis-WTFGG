# ──────────────────────────────────────────────────────────────────────────────
def _self_test() -> None:
    """全链路自测；WALPURGIS_DEBUG=1 时输出详细断点信息。"""
    _dbg("self_test", "开始自测")

    # 1. RefKind 枚举
    assert SharedWorkflowRefKind.PINNED.is_stable()
    assert not SharedWorkflowRefKind.PINNED.is_live()
    assert SharedWorkflowRefKind.ROLLING.is_live()
    assert not SharedWorkflowRefKind.ROLLING.is_stable()
    _dbg("self_test", "✓ RefKind 枚举断言通过")

    # 2. SharedWorkflowRef
    ref = SharedWorkflowRef(
        repo="rapidsai/shared-workflows",
        workflow_path=".github/workflows/conda-cpp-build.yaml",
        kind=SharedWorkflowRefKind.ROLLING,
        ref_value="main",
        host_workflow=".github/workflows/build.yaml",
    )
    assert "@main" in ref.uses_string()
    assert "ROLLING" in ref.audit_line()
    _dbg("self_test", f"✓ SharedWorkflowRef: {ref}")

    # 3. WorkflowMigrationRecord
    rec = SharedWorkflowBranchManifest.MIGRATION
    assert "cuda-13.1.0" in rec.summary()
    assert "main" in rec.summary()
    assert rec.workflow_count == 30
    assert len(rec.affected_files) == 4
    _dbg("self_test", f"✓ MigrationRecord: {rec.summary()}")

    # 4. Manifest 构造
    manifest = SharedWorkflowBranchManifest()
    refs = manifest.all_refs()
    assert len(refs) == 30, f"期望 30 条引用，实际 {len(refs)}"
    _dbg("self_test", f"✓ Manifest.all_refs(): {len(refs)} 条")

    # 5. rolling_ratio = 1.0（全部切换后）
    ratio = manifest.rolling_ratio()
    assert ratio == 1.0, f"期望 1.0，实际 {ratio}"
    _dbg("self_test", f"✓ rolling_ratio = {ratio:.1%}")

    # 6. refs_by_host 过滤
    build_refs = manifest.refs_by_host(".github/workflows/build.yaml")
    assert len(build_refs) == 10, f"build.yaml 期望 10 条，实际 {len(build_refs)}"
    _dbg("self_test", f"✓ refs_by_host(build.yaml) = {len(build_refs)} 条")

    # 7. pr.yaml refs
    pr_refs = manifest.refs_by_host(".github/workflows/pr.yaml")
    assert len(pr_refs) == 15, f"pr.yaml 期望 15 条，实际 {len(pr_refs)}"
    _dbg("self_test", f"✓ refs_by_host(pr.yaml) = {len(pr_refs)} 条")

    # 8. test.yaml refs
    test_refs = manifest.refs_by_host(".github/workflows/test.yaml")
    assert len(test_refs) == 4, f"test.yaml 期望 4 条，实际 {len(test_refs)}"
    _dbg("self_test", f"✓ refs_by_host(test.yaml) = {len(test_refs)} 条")

    # 9. audit_report 包含关键字段
    report = manifest.audit_report()
    assert "2910605" in report
    assert "cuda-13.1.0" in report
    assert "100.0%" in report
    _dbg("self_test", "✓ audit_report 关键字段断言通过")

    # 10. audit_line / summary 格式
    assert "walpurgis-migration" in rec.audit_line()
    assert "→" in rec.summary()
    _dbg("self_test", "✓ audit_line / summary 格式断言通过")

    print("shared_workflow_branch_policy: 全部 10 项自测通过 ✓")
    _dbg("self_test", "自测完成")


if __name__ == "__main__":
    _self_test()
    manifest = SharedWorkflowBranchManifest()
    print(manifest.audit_report())
