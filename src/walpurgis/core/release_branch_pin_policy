@dataclass(frozen=True)
class SharedWorkflowRef:
    """封装单条 rapidsai/shared-workflows 引用。

    上游 f3d215f 修改的每一行 `uses:` 字段均对应一个 SharedWorkflowRef 实例。
    Walpurgis 将这些散落在 4 个 YAML 文件中的 28 处引用结构化为可查询记录。

    Attributes:
        workflow_path: shared-workflows 仓库内的工作流路径，
                       例如 ".github/workflows/conda-cpp-build.yaml"
        ref_before:    f3d215f 变更前的引用（通常为 "main"）
        ref_after:     f3d215f 变更后的引用（通常为 "release/25.12"）
        source_file:   上游仓库中包含此引用的 workflow 文件路径
        occurrence:    同一 source_file 中此引用的出现次数（便于批量审计）
    """
    workflow_path: str
    ref_before: str
    ref_after: str
    source_file: str
    occurrence: int = 1

    def strategy_before(self) -> PinStrategy:
        """返回变更前的 PinStrategy。"""
        _dbg("STRATEGY_BEFORE", f"resolving strategy for ref_before={self.ref_before!r}")
        return _classify_ref(self.ref_before)

    def strategy_after(self) -> PinStrategy:
        """返回变更后的 PinStrategy。"""
        _dbg("STRATEGY_AFTER", f"resolving strategy for ref_after={self.ref_after!r}")
        return _classify_ref(self.ref_after)

    def is_pin_upgrade(self) -> bool:
        """返回此次变更是否是从 FLOATING 升级到更具确定性的策略。"""
        return (
            not self.strategy_before().is_deterministic()
            and self.strategy_after().is_deterministic()
        )

    def audit_line(self) -> str:
        """产出单行可读审计描述，供 PinAuditReport 汇总使用。"""
        direction = "↑PIN" if self.is_pin_upgrade() else "→CHANGE"
        return (
            f"  [{direction}] {self.source_file}: "
            f"{self.workflow_path}@{self.ref_before} → @{self.ref_after} "
            f"(×{self.occurrence})"
        )


def _classify_ref(ref: str) -> PinStrategy:
    """将 ref 字符串分类为 PinStrategy。

    判定规则：
      - 长度 40 且全为十六进制字符 → SHA
      - 以 "release/" 或其他非 "main"/"nightly" 前缀开头的具名分支 → PINNED
      - "main" / "nightly" / "latest" → FLOATING
    """
    _dbg("CLASSIFY_REF", f"classifying ref={ref!r}")
    if len(ref) == 40 and all(c in "0123456789abcdef" for c in ref.lower()):
        return PinStrategy.SHA
    if ref in ("main", "nightly", "latest", "HEAD"):
        return PinStrategy.FLOATING
    # 具名分支（如 release/25.12、cuda-13.2.0 等）视为 PINNED
    return PinStrategy.PINNED


