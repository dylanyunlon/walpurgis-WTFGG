# ── 枚举：分支引用策略 ───────────────────────────────────────────────────────

class PinStrategy(Enum):
    """描述一个 shared-workflow 引用的「时间性」类型。

    上游 f3d215f 将所有引用从 FLOATING 切换至 PINNED，
    触发条件是进入 release/25.12 冻结窗口。

    FLOATING —— @main: 跟随 HEAD，随时可能变化，适合日常开发期。
    PINNED   —— @release/X.Y: 指向命名 release 快照，语义稳定。
    SHA      —— @<40-char-hash>: 指向精确提交，不可变，最严格的 pinning 形式。
    """
    FLOATING = "floating"
    PINNED = "pinned"
    SHA = "sha"

    def is_deterministic(self) -> bool:
        """返回该策略是否在任意时刻都产生确定性结果。

        FLOATING 引用随上游 push 而漂移，不具备确定性；
        PINNED 和 SHA 均不随上游变化而变化（前提是 release 分支为冻结态）。
        """
        return self in (PinStrategy.PINNED, PinStrategy.SHA)

    def freeze_risk(self) -> str:
        """返回在 release 冻结窗口内使用此策略的风险描述。"""
        _dbg("FREEZE_RISK", f"computing freeze_risk for strategy={self.value}")
        if self is PinStrategy.FLOATING:
            return "HIGH: @main 随时可能引入破坏 release 构建的 breaking change"
        if self is PinStrategy.PINNED:
            return "LOW: @release/X.Y 指向冻结快照，变更须经过 release 分支 PR 审查"
        return "NONE: SHA pinning 完全不可变"


_dbg("ENUM_INIT", f"PinStrategy 枚举已加载，共 {len(PinStrategy)} 种策略")


