class ReleasePinManifest:
    """汇总 f3d215f 中全部 workflow 引用的 pinning 操作。

    上游 f3d215f 将 4 个 workflow 文件中共 28 处 `@main` 引用统一替换为
    `@release/25.12`，加上 RAPIDS_BRANCH 文件和 cmake 脚本注释共 6 个文件。
    本 manifest 将这些操作结构化为可查询、可审计的 Python 对象集合。

    Walpurgis 不运行这些 workflow，但可通过此 manifest 追踪「上游在
    release/25.12 冻结窗口期间共钉版了哪些 shared-workflow 组件」。
    """

    TARGET_RELEASE: str = "release/25.12"
    SOURCE_COMMIT: str = "f3d215f"

    def __init__(self) -> None:
        _dbg("MANIFEST_INIT", f"构建 ReleasePinManifest for commit {self.SOURCE_COMMIT}")
        self._refs: List[SharedWorkflowRef] = _build_f3d215f_refs()
        _dbg("MANIFEST_BUILT", f"共加载 {len(self._refs)} 条 SharedWorkflowRef 记录")

    def all_refs(self) -> List[SharedWorkflowRef]:
        """返回全部 workflow 引用记录。"""
        return list(self._refs)

    def pin_upgrades(self) -> List[SharedWorkflowRef]:
        """返回所有从 FLOATING → PINNED/SHA 的升级记录。"""
        _dbg("PIN_UPGRADES", "过滤 pin_upgrade=True 的记录")
        return [r for r in self._refs if r.is_pin_upgrade()]

    def by_source_file(self) -> Dict[str, List[SharedWorkflowRef]]:
        """按来源 workflow 文件分组返回所有引用记录。"""
        _dbg("BY_SOURCE_FILE", "按 source_file 分组")
        result: Dict[str, List[SharedWorkflowRef]] = {}
        for ref in self._refs:
            result.setdefault(ref.source_file, []).append(ref)
        return result

    def total_occurrences(self) -> int:
        """返回本次 pinning 操作涉及的 workflow 引用总出现次数（含重复行）。"""
        return sum(r.occurrence for r in self._refs)

    def summary(self) -> str:
        """返回单行摘要，供快速审计。"""
        upgrades = len(self.pin_upgrades())
        files = len(self.by_source_file())
        total = self.total_occurrences()
        return (
            f"f3d215f ReleasePinManifest: "
            f"{files} files, {len(self._refs)} unique refs, "
            f"{total} total occurrences, {upgrades} pin upgrades → {self.TARGET_RELEASE}"
        )


