@dataclass
class PinAuditReport:
    """f3d215f pinning 操作的完整可审计报告。

    Attributes:
        manifest:       被审计的 ReleasePinManifest 实例
        walpurgis_skip: Walpurgis 迁移决定（True = 全部 SKIP）
        skip_reason:    SKIP 的原因描述
    """
    manifest: ReleasePinManifest
    walpurgis_skip: bool = True
    skip_reason: str = (
        "Walpurgis 无 GitHub Actions CI 体系，无 rapidsai/shared-workflows 调用链，"
        "无 RAPIDS_BRANCH 配置文件；全部 6 个变更文件均为 CI/workflow 类型，"
        "对 Python/C++ 运行时代码零影响。"
    )

    def render(self) -> str:
        """生成完整可读审计报告字符串。"""
        _dbg("RENDER", "生成 PinAuditReport 文本")
        lines: List[str] = [
            "=" * 72,
            f"Walpurgis 迁移审计报告 — commit f3d215f",
            f"目标 release 分支: {self.manifest.TARGET_RELEASE}",
            f"摘要: {self.manifest.summary()}",
            "",
            f"Walpurgis 迁移决定: {'SKIP（全部文件）' if self.walpurgis_skip else '部分迁移'}",
            f"SKIP 原因: {self.skip_reason}",
            "",
            "变更文件及引用明细:",
        ]
        for src_file, refs in self.manifest.by_source_file().items():
            lines.append(f"  [{src_file}]")
            for ref in refs:
                lines.append(ref.audit_line())
        lines.append("=" * 72)
        return "\n".join(lines)


