    check("get_deprecated_cuda_version() == CUDA_13_0", get_deprecated_cuda_version() == v130)

    issues = verify_cuda_version_in_yaml("cuda_version: 13.1")
    check("verify: 已升级 → 无 issues", len(issues) == 0)

    issues_old = verify_cuda_version_in_yaml("cuda_version: 13.0")
    check("verify: 未升级 → 有 issues", len(issues_old) > 0)

    # 10. 幂等性（连续调用结果一致）
    s1 = mig.diff_stat_summary()
    s2 = mig.diff_stat_summary()
    check("diff_stat_summary 幂等", s1 == s2)

    print(f"\n[cuda131_support_policy ba506a8] 自检完成: {passed}/{total} 通过")
    if passed < total:
        sys.exit(1)


