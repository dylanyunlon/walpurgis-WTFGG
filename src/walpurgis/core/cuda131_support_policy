    check("insertions == 240", mig.insertions == 240)
    check("deletions == 236", mig.deletions == 236)
    check("diff_stat_summary 含 13.0 → 13.1", "13.0" in mig.diff_stat_summary() and "13.1" in mig.diff_stat_summary())
    check("4 个 scope 全覆盖", len(mig.scopes) == 4)

    affected = mig.affected_files()
    check("affected 含 DEVCONTAINER scope", MigrationScope.DEVCONTAINER in affected)
    check("affected DEVCONTAINER added 含 cuda13.1-conda",
          any("cuda13.1-conda" in f for f in affected[MigrationScope.DEVCONTAINER]["added"]))
    check("affected CONDA_ENV added 含 cuda-131",
          any("cuda-131" in f for f in affected[MigrationScope.CONDA_ENV]["added"]))

    # 9. 便捷查询函数
