# DependenciesYamlPatch — dependencies.yaml cuda_version 字段变更文档化
# 上游: 直接修改 YAML，10 行变更，无 Python 层可查询记录
# 改写: dataclass 存档 before/after，patch_summary() 生成可读摘要
# ─────────────────────────────────────────────────────────────

@dataclass(frozen=True)
class DependenciesYamlPatch:
    """
    dependencies.yaml 的 cuda_version 字段版本升级记录。

    上游 ba506a8 变更: "13.0" → "13.1"（10 处）
    """
    field_name: str
    before: CudaMinorVersion
    after: CudaMinorVersion
    affected_lines: int
    commit: str = "ba506a8"
    file_path: str = "dependencies.yaml"

    def patch_summary(self) -> str:
        """生成人类可读的补丁摘要。"""
        summary = (
            f"[{self.commit}] {self.file_path}: "
            f"{self.field_name}: {self.before.value!r} → {self.after.value!r} "
            f"({self.affected_lines} 处)"
        )
        _dbg("DependenciesYamlPatch.patch_summary", f"→ {summary!r}")
        return summary

    def is_applied(self, yaml_content: str) -> bool:
        """
        检查给定的 YAML 内容是否已应用本补丁。

        判断逻辑：after 版本字符串存在且 before 版本字符串不存在（或仅作为历史注释出现）。

        Args:
            yaml_content: dependencies.yaml 文件内容字符串

        Returns:
            True 如果补丁已应用
        """
        _dbg("DependenciesYamlPatch.is_applied", f"检查 {self.field_name} 补丁状态")
        after_present = self.after.value in yaml_content
        before_present = self.before.value in yaml_content
        applied = after_present and not before_present
        _dbg("DependenciesYamlPatch.is_applied",
             f"after_present={after_present} before_present={before_present} → applied={applied}")
        return applied

    def __str__(self) -> str:
        return self.patch_summary()


