@dataclass(frozen=True)
class DevcontainerSpec:
    """
    单个 devcontainer 配置的结构化表示。

    对应上游 .devcontainer/{cuda_version.label}-{mode.value}/devcontainer.json。

    Attributes:
        cuda_version:  目标 CUDA 次版本
        mode:          包管理器模式（conda/pip）
        rapids_ver:    RAPIDS 版本字符串（devcontainer feature 版本）
        project_name:  工作区项目名（用于挂载路径和容器命名）
    """
    cuda_version: CudaMinorVersion
    mode: DevcontainerMode
    rapids_ver: str = "26.02"
    project_name: str = "cugraph-gnn"

    @property
    def devcontainer_dir(self) -> str:
        """对应的 .devcontainer 子目录名（如 cuda13.1-conda）。"""
        name = f"{self.cuda_version.label}-{self.mode.value}"
        _dbg("DevcontainerSpec.devcontainer_dir", f"→ {name!r}")
        return name

    @property
    def container_name(self) -> str:
        """
        runArgs --name 字段值（含 shell 变量引用）。

        上游: "${localEnv:USER:anon}-rapids-${localWorkspaceFolderBasename}-26.02-cuda13.1-conda"
        """
        name = (
            "${localEnv:USER:anon}"
            + self.mode.container_name_tag(self.cuda_version, self.rapids_ver)
        )
        _dbg("DevcontainerSpec.container_name", f"→ {name!r}")
        return name

    @property
    def base_image(self) -> str:
        """BASE 构建参数（对应 devcontainer.json args.BASE）。"""
        return self.mode.base_image(self.cuda_version)

    @property
    def workspace_mount(self) -> str:
        """workspaceMount 字段（绑定挂载到 /home/coder/{project_name}）。"""
        mount = (
            "source=${localWorkspaceFolder},"
            f"target=/home/coder/{self.project_name},"
            "type=bind,consistency=consistent"
        )
        _dbg("DevcontainerSpec.workspace_mount", f"→ {mount!r}")
        return mount

    def env_dir_mount(self) -> str:
        """
        conda envs / pip venvs 挂载配置（mounts 数组中的环境目录条目）。

        上游 conda 模式:
          source=${localWorkspaceFolder}/../.conda/${localWorkspaceFolderBasename}-cuda13.1-envs
          target=/home/coder/.conda/envs
        上游 pip 模式:
          source=${localWorkspaceFolder}/../.local/share/${localWorkspaceFolderBasename}-cuda13.1-venvs
          target=/home/coder/.local/share/venvs
        """
        _dbg("DevcontainerSpec.env_dir_mount", f"mode={self.mode.value} cuda={self.cuda_version.value}")
        if self.mode == DevcontainerMode.CONDA:
            src_suffix = (
                f"${{localWorkspaceFolder}}/../.conda/"
                f"${{localWorkspaceFolderBasename}}-{self.cuda_version.label}-envs"
            )
            tgt = "/home/coder/.conda/envs"
        else:
            src_suffix = (
                f"${{localWorkspaceFolder}}/../.local/share/"
                f"${{localWorkspaceFolderBasename}}-{self.cuda_version.label}-venvs"
            )
            tgt = "/home/coder/.local/share/venvs"
        mount = f"source={src_suffix},target={tgt},type=bind,consistency=consistent"
        _dbg("DevcontainerSpec.env_dir_mount", f"→ {mount!r}")
        return mount

    def summary(self) -> str:
        """生成该 devcontainer 配置的单行摘要，供日志/报告使用。"""
        return (
            f"DevcontainerSpec("
            f"dir={self.devcontainer_dir!r}, "
            f"cuda={self.cuda_version.value}, "
            f"mode={self.mode.value}, "
            f"base={self.base_image!r})"
        )

    def __str__(self) -> str:
        return self.summary()


def make_devcontainer_matrix(
    cuda_versions: Tuple[CudaMinorVersion, ...] = (
        CudaMinorVersion.CUDA_13_0,
        CudaMinorVersion.CUDA_13_1,
    ),
    modes: Tuple[DevcontainerMode, ...] = (
        DevcontainerMode.CONDA,
        DevcontainerMode.PIP,
    ),
) -> List[DevcontainerSpec]:
    """
    生成 devcontainer 配置矩阵（CUDA 版本 × 包管理器模式）。

    上游：四份手动维护的 JSON 文件
    改写：笛卡尔积自动生成，消除手动同步风险

    Args:
        cuda_versions: 目标 CUDA 版本集合
        modes:         包管理器模式集合

    Returns:
        DevcontainerSpec 列表，顺序为 (cuda×mode) 笛卡尔积
    """
    _dbg("make_devcontainer_matrix", f"cuda_versions={[v.value for v in cuda_versions]} modes={[m.value for m in modes]}")
    specs = [
        DevcontainerSpec(cuda_version=cv, mode=mode)
        for cv in cuda_versions
        for mode in modes
    ]
    _dbg("make_devcontainer_matrix", f"→ 生成 {len(specs)} 个 DevcontainerSpec")
    return specs


