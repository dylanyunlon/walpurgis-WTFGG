@unique
class CudaMinorVersion(Enum):
    """
    CUDA 次版本号枚举，对应 ba506a8 迁移中 13.0 → 13.1 的切换。

    CUDA_13_0  — CUDA 13.0（ba506a8 之前的版本，已废弃）
    CUDA_13_1  — CUDA 13.1（ba506a8 引入的目标版本）
    """
    CUDA_13_0 = "13.0"
    CUDA_13_1 = "13.1"

    @property
    def label(self) -> str:
        """返回用于文件名/目录名的版本标签（如 cuda13.0）。"""
        return f"cuda{self.value}"

    @property
    def conda_label(self) -> str:
        """返回 conda 环境目录的版本标签（如 cuda-130）。"""
        # "13.0" → "130", "13.1" → "131"
        return f"cuda-{self.value.replace('.', '')}"

    def is_supported(self) -> bool:
        """ba506a8 之后，仅 CUDA_13_1 受支持。"""
        supported = self == CudaMinorVersion.CUDA_13_1
        _dbg("CudaMinorVersion.is_supported", f"{self.value} → {supported}")
        return supported

    def successor(self) -> Optional["CudaMinorVersion"]:
        """
        返回本版本的后继版本（用于建模迁移关系）。

        13.0 → 13.1；13.1 无已知后继（截至 ba506a8）。
        """
        _SUCCESSOR: Dict[CudaMinorVersion, Optional[CudaMinorVersion]] = {
            CudaMinorVersion.CUDA_13_0: CudaMinorVersion.CUDA_13_1,
            CudaMinorVersion.CUDA_13_1: None,
        }
        result = _SUCCESSOR.get(self)
        _dbg("CudaMinorVersion.successor", f"{self.value} → {result}")
        return result

    def __str__(self) -> str:
        return self.value


_dbg("module", f"CudaMinorVersion 枚举初始化完成: {[v.value for v in CudaMinorVersion]}")


