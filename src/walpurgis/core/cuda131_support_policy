@unique
class DevcontainerMode(Enum):
    """
    devcontainer 包管理器模式，对应 .devcontainer/ 下 conda/pip 两个子目录。

    CONDA — 使用 conda/mamba 作为包管理器
    PIP   — 使用 pip + venv 作为包管理器
    """
    CONDA = "conda"
    PIP = "pip"

    def base_image(self, cuda_version: CudaMinorVersion) -> str:
        """
        返回对应 CUDA 版本的 BASE 镜像字符串。

        上游 devcontainer.json 中 "args.BASE" 字段：
          conda: 与 CUDA 版本无关（使用通用 mambaforge 镜像）
          pip:   镜像名中包含 cuda 版本号，需随 CUDA 版本更新
        """
        _dbg("DevcontainerMode.base_image", f"mode={self.value} cuda={cuda_version.value}")
        if self == DevcontainerMode.CONDA:
            img = "rapidsai/devcontainers:26.02-cpp-mambaforge"
        else:
            # pip 模式：镜像名编码了 CUDA 版本
            # 上游: cuda13.0-ucx1.19.0-openmpi5.0.7 → cuda13.1-ucx1.19.0-openmpi5.0.7
            img = (
                f"rapidsai/devcontainers:26.02-cpp-"
                f"{cuda_version.label}-ucx1.19.0-openmpi5.0.7"
            )
        _dbg("DevcontainerMode.base_image", f"→ {img!r}")
        return img

    def env_dir_suffix(self, cuda_version: CudaMinorVersion, project: str = "cugraph") -> str:
        """
        返回环境目录后缀，供 devcontainer.json mounts 字段使用。

        conda: .conda/${project}-cuda13.x-envs
        pip:   .local/share/${project}-cuda13.x-venvs
        """
        _dbg("DevcontainerMode.env_dir_suffix", f"mode={self.value} cuda={cuda_version.value}")
        if self == DevcontainerMode.CONDA:
            suffix = f".conda/{project}-{cuda_version.label}-envs"
        else:
            suffix = f".local/share/{project}-{cuda_version.label}-venvs"
        _dbg("DevcontainerMode.env_dir_suffix", f"→ {suffix!r}")
        return suffix

    def container_name_tag(self, cuda_version: CudaMinorVersion, rapids_ver: str = "26.02") -> str:
        """
        返回 runArgs --name 字段的版本+模式标签部分。

        上游: -rapids-${basename}-26.02-cuda13.0-conda
        改写: 封装为方法，避免各 JSON 手动拼接
        """
        tag = f"-rapids-${{localWorkspaceFolderBasename}}-{rapids_ver}-{cuda_version.label}-{self.value}"
        _dbg("DevcontainerMode.container_name_tag", f"→ {tag!r}")
        return tag


