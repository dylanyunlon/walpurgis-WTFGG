def verify_cuda_version_in_yaml(yaml_content: str) -> List[str]:
    """
    验证给定 YAML 内容是否已应用 ba506a8 的 CUDA 版本升级。

    Args:
        yaml_content: 目标 YAML 文件内容字符串

    Returns:
        问题列表；列表为空表示版本已就绪
    """
    _dbg("verify_cuda_version_in_yaml", f"内容长度={len(yaml_content)} 字符")
    issues: List[str] = []
    patch = DEPENDENCIES_YAML_PATCH_BA506A8

    if patch.after.value in yaml_content:
        _dbg("verify_cuda_version_in_yaml", f"✓ {patch.after.value} 已存在")
    elif patch.before.value in yaml_content:
        issues.append(
            f"[ba506a8] cuda_version 仍为旧版 {patch.before.value!r}，"
            f"应升级至 {patch.after.value!r}"
        )
        _dbg("verify_cuda_version_in_yaml", f"✗ 旧版本 {patch.before.value!r} 仍存在")
    else:
        _dbg("verify_cuda_version_in_yaml", "? cuda_version 字段未找到，跳过")

    _dbg("verify_cuda_version_in_yaml", f"验证完成，issues={issues}")
    return issues


