    def __str__(self) -> str:
        return f"EnvMatrixKey(cuda={self.cuda_version.value}, arch={self.cpu_arch.value})"


@dataclass
class CudaEnvMatrix:
    """
    CUDA × CPU 架构环境矩阵，对应 ba506a8 新增/删除的 conda 环境 YAML 文件集合。

    上游：四个独立 YAML 文件，靠文件名区分；版本切换时需手动重命名
    改写：矩阵显式建模，added()/removed() 方法枚举版本切换的增删文件集合

    Attributes:
        supported_cuda:   当前支持的 CUDA 版本（ba506a8 后: CUDA_13_1）
        deprecated_cuda:  已废弃的 CUDA 版本（ba506a8 后: CUDA_13_0）
        architectures:    支持的 CPU 架构集合
    """
    supported_cuda: CudaMinorVersion = CudaMinorVersion.CUDA_13_1
    deprecated_cuda: CudaMinorVersion = CudaMinorVersion.CUDA_13_0
    architectures: Tuple[CpuArch, ...] = (CpuArch.AARCH64, CpuArch.X86_64)

    def matrix_keys(self, cuda_version: Optional[CudaMinorVersion] = None) -> List[EnvMatrixKey]:
        """
        枚举指定 CUDA 版本的所有矩阵坐标。

        Args:
            cuda_version: 目标 CUDA 版本；None 时使用 supported_cuda

        Returns:
            EnvMatrixKey 列表（按架构排序）
        """
        cv = cuda_version if cuda_version is not None else self.supported_cuda
        _dbg("CudaEnvMatrix.matrix_keys", f"cuda_version={cv.value}")
        keys = [EnvMatrixKey(cuda_version=cv, cpu_arch=arch) for arch in self.architectures]
        _dbg("CudaEnvMatrix.matrix_keys", f"→ {[str(k) for k in keys]}")
        return keys

    def added_files(self) -> List[str]:
        """ba506a8 新增的 conda 环境 YAML 文件名列表（CUDA 13.1 矩阵）。"""
        _dbg("CudaEnvMatrix.added_files", f"cuda={self.supported_cuda.value}")
        files = [k.yaml_filename for k in self.matrix_keys(self.supported_cuda)]
        files += [k.cugraph_pyg_yaml_filename for k in self.matrix_keys(self.supported_cuda)]
        _dbg("CudaEnvMatrix.added_files", f"→ {files}")
        return files

    def removed_files(self) -> List[str]:
        """ba506a8 删除的 conda 环境 YAML 文件名列表（CUDA 13.0 矩阵）。"""
        _dbg("CudaEnvMatrix.removed_files", f"cuda={self.deprecated_cuda.value}")
        files = [k.yaml_filename for k in self.matrix_keys(self.deprecated_cuda)]
        files += [k.cugraph_pyg_yaml_filename for k in self.matrix_keys(self.deprecated_cuda)]
        _dbg("CudaEnvMatrix.removed_files", f"→ {files}")
        return files

    def migration_delta(self) -> Tuple[List[str], List[str]]:
        """
        返回 (added, removed) 文件名元组，汇总 ba506a8 的文件级变更。

        Returns:
            (added_files, removed_files)
        """
        _dbg("CudaEnvMatrix.migration_delta", "计算增删文件集合")
        added = self.added_files()
        removed = self.removed_files()
        _dbg("CudaEnvMatrix.migration_delta", f"added={len(added)}, removed={len(removed)}")
        return added, removed


