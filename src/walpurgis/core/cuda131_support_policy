def _self_test() -> None:
    """全路径自测，覆盖所有公开 API。"""
    import sys

    print("[cuda131_support_policy ba506a8] 自检启动")
    passed = 0
    total = 0

    def check(name: str, condition: bool) -> None:
        nonlocal passed, total
        total += 1
        status = "PASS" if condition else "FAIL"
        print(f"  [{status}] {name}")
        if condition:
            passed += 1
        else:
            import traceback
            traceback.print_stack()

    # 1. CudaMinorVersion 基础属性
    v130 = CudaMinorVersion.CUDA_13_0
    v131 = CudaMinorVersion.CUDA_13_1
    check("v130.label == 'cuda13.0'", v130.label == "cuda13.0")
    check("v131.label == 'cuda13.1'", v131.label == "cuda13.1")
    check("v130.conda_label == 'cuda-130'", v130.conda_label == "cuda-130")
    check("v131.conda_label == 'cuda-131'", v131.conda_label == "cuda-131")
    check("v130.is_supported() == False", not v130.is_supported())
    check("v131.is_supported() == True", v131.is_supported())
    check("v130.successor() == v131", v130.successor() == v131)
    check("v131.successor() is None", v131.successor() is None)

    # 2. DevcontainerMode
    conda = DevcontainerMode.CONDA
    pip   = DevcontainerMode.PIP
    check("conda base_image 不含 cuda 版本号", "mambaforge" in conda.base_image(v131))
    check("pip base_image 含 cuda13.1", "cuda13.1" in pip.base_image(v131))
    check("pip base_image 含 cuda13.0 (旧版)", "cuda13.0" in pip.base_image(v130))
    check("conda env_dir_suffix 含 cuda13.1-envs", "cuda13.1-envs" in conda.env_dir_suffix(v131))
    check("pip env_dir_suffix 含 cuda13.1-venvs", "cuda13.1-venvs" in pip.env_dir_suffix(v131))

    # 3. DevcontainerSpec
    spec = DevcontainerSpec(cuda_version=v131, mode=conda)
    check("devcontainer_dir == 'cuda13.1-conda'", spec.devcontainer_dir == "cuda13.1-conda")
    check("base_image 含 mambaforge", "mambaforge" in spec.base_image)
    check("container_name 含 cuda13.1-conda", "cuda13.1-conda" in spec.container_name)
    check("env_dir_mount 含 cuda13.1-envs", "cuda13.1-envs" in spec.env_dir_mount())

    spec_pip = DevcontainerSpec(cuda_version=v131, mode=pip)
    check("pip devcontainer_dir == 'cuda13.1-pip'", spec_pip.devcontainer_dir == "cuda13.1-pip")
    check("pip env_dir_mount 含 cuda13.1-venvs", "cuda13.1-venvs" in spec_pip.env_dir_mount())

    # 4. make_devcontainer_matrix
    matrix_all = make_devcontainer_matrix()
    check("矩阵含 4 个 spec", len(matrix_all) == 4)
    dirs = {s.devcontainer_dir for s in matrix_all}
    check("矩阵包含 cuda13.0-conda", "cuda13.0-conda" in dirs)
    check("矩阵包含 cuda13.1-pip",   "cuda13.1-pip"   in dirs)

    matrix_131_only = make_devcontainer_matrix(
        cuda_versions=(v131,),
        modes=(DevcontainerMode.CONDA, DevcontainerMode.PIP),
    )
    check("仅 13.1 矩阵含 2 个 spec", len(matrix_131_only) == 2)

    # 5. EnvMatrixKey
    key = EnvMatrixKey(cuda_version=v131, cpu_arch=CpuArch.X86_64)
    check("yaml_filename 正确", key.yaml_filename == "all_cuda-131_arch-x86_64.yaml")
    check("cugraph_pyg_yaml_filename 正确", key.cugraph_pyg_yaml_filename == "cugraph_pyg_dev_cuda-131_arch-x86_64.yaml")

    key_aarch = EnvMatrixKey(cuda_version=v130, cpu_arch=CpuArch.AARCH64)
    check("aarch64 yaml_filename 正确", key_aarch.yaml_filename == "all_cuda-130_arch-aarch64.yaml")

    # 6. CudaEnvMatrix
    env_matrix = CudaEnvMatrix()
    added, removed = env_matrix.migration_delta()
    check("added 含 4 个文件（2 conda + 2 pyg）", len(added) == 4)
    check("removed 含 4 个文件（2 conda + 2 pyg）", len(removed) == 4)
    check("added 含 cuda-131", any("cuda-131" in f for f in added))
    check("removed 含 cuda-130", any("cuda-130" in f for f in removed))

    # 7. DependenciesYamlPatch
    patch = DEPENDENCIES_YAML_PATCH_BA506A8
