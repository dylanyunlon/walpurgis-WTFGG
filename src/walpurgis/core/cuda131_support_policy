# MigrationScope / CudaVersionMigration — 整次迁移的可审计记录
# 上游: 无迁移记录，全靠 git diff 追溯
# 改写: 显式化迁移范围，affected_files() 枚举所有受影响文件
# ─────────────────────────────────────────────────────────────

@unique
class MigrationScope(Enum):
    """
    ba506a8 迁移涉及的变更范围分类。

    DEVCONTAINER  — .devcontainer/ 下的 JSON 配置文件
    CONDA_ENV     — conda/environments/ 下的 YAML 环境文件
    CUGRAPH_PYG   — python/cugraph-pyg/conda/environments/ 下的 YAML 文件
    DEPENDENCIES  — 顶层 dependencies.yaml
    """
    DEVCONTAINER = "devcontainer"
    CONDA_ENV    = "conda_env"
    CUGRAPH_PYG  = "cugraph_pyg"
    DEPENDENCIES = "dependencies"

    @property
    def human_label(self) -> str:
        labels = {
            MigrationScope.DEVCONTAINER: ".devcontainer/ JSON 配置",
            MigrationScope.CONDA_ENV:    "conda/environments/ YAML",
            MigrationScope.CUGRAPH_PYG:  "cugraph-pyg conda/environments/ YAML",
            MigrationScope.DEPENDENCIES: "dependencies.yaml",
        }
        return labels[self]


@dataclass(frozen=True)
class CudaVersionMigration:
    """
    CUDA 版本升级迁移的可审计记录，对应 ba506a8 (13.0 → 13.1)。

    Attributes:
        commit:       git commit hash
        from_version: 迁移前 CUDA 版本
        to_version:   迁移后 CUDA 版本
        scopes:       本次迁移涉及的变更范围集合
        files_changed: 总变更文件数（上游 diff 统计）
        insertions:   新增行数
        deletions:    删除行数
    """
    commit: str
    from_version: CudaMinorVersion
    to_version: CudaMinorVersion
    scopes: FrozenSet[MigrationScope]
    files_changed: int
    insertions: int
    deletions: int

    def scope_labels(self) -> List[str]:
        """返回所有变更范围的人类可读标签列表。"""
        labels = [s.human_label for s in sorted(self.scopes, key=lambda s: s.value)]
        _dbg("CudaVersionMigration.scope_labels", f"→ {labels}")
        return labels

    def affected_files(self, env_matrix: Optional[CudaEnvMatrix] = None) -> Dict[MigrationScope, Dict[str, List[str]]]:
        """
        枚举所有受影响的文件，按 MigrationScope 分组并区分 added/removed。

        Args:
            env_matrix: conda 环境矩阵；None 时使用默认实例

        Returns:
            {scope: {"added": [...], "removed": [...]}} 的嵌套字典
        """
        _dbg("CudaVersionMigration.affected_files", f"commit={self.commit}")
        matrix = env_matrix or CudaEnvMatrix(
            supported_cuda=self.to_version,
            deprecated_cuda=self.from_version,
        )

        result: Dict[MigrationScope, Dict[str, List[str]]] = {}

        if MigrationScope.DEVCONTAINER in self.scopes:
            old_specs = [
                DevcontainerSpec(cuda_version=self.from_version, mode=m)
                for m in (DevcontainerMode.CONDA, DevcontainerMode.PIP)
            ]
            new_specs = [
                DevcontainerSpec(cuda_version=self.to_version, mode=m)
                for m in (DevcontainerMode.CONDA, DevcontainerMode.PIP)
            ]
            result[MigrationScope.DEVCONTAINER] = {
                "added":   [f".devcontainer/{s.devcontainer_dir}/devcontainer.json" for s in new_specs],
                "removed": [f".devcontainer/{s.devcontainer_dir}/devcontainer.json" for s in old_specs],
            }
            _dbg("CudaVersionMigration.affected_files",
                 f"DEVCONTAINER: +{len(new_specs)} -{len(old_specs)}")

        if MigrationScope.CONDA_ENV in self.scopes:
            added_env, removed_env = matrix.migration_delta()
            # 过滤只保留 conda/environments/ 下的文件（非 cugraph_pyg）
            added_base = [f for f in added_env if f.startswith("all_")]
            removed_base = [f for f in removed_env if f.startswith("all_")]
            result[MigrationScope.CONDA_ENV] = {
                "added":   [f"conda/environments/{f}" for f in added_base],
                "removed": [f"conda/environments/{f}" for f in removed_base],
            }
            _dbg("CudaVersionMigration.affected_files",
                 f"CONDA_ENV: +{len(added_base)} -{len(removed_base)}")

        if MigrationScope.CUGRAPH_PYG in self.scopes:
            added_pyg, removed_pyg = matrix.migration_delta()
            added_pyg_f = [f for f in added_pyg if f.startswith("cugraph_pyg")]
            removed_pyg_f = [f for f in removed_pyg if f.startswith("cugraph_pyg")]
            result[MigrationScope.CUGRAPH_PYG] = {
                "added":   [f"python/cugraph-pyg/conda/environments/{f}" for f in added_pyg_f],
                "removed": [f"python/cugraph-pyg/conda/environments/{f}" for f in removed_pyg_f],
            }
            _dbg("CudaVersionMigration.affected_files",
                 f"CUGRAPH_PYG: +{len(added_pyg_f)} -{len(removed_pyg_f)}")

        if MigrationScope.DEPENDENCIES in self.scopes:
            result[MigrationScope.DEPENDENCIES] = {
                "added":   [],
                "removed": [],
                "modified": ["dependencies.yaml"],  # type: ignore[dict-item]
            }
            _dbg("CudaVersionMigration.affected_files", "DEPENDENCIES: 1 modified")

        return result

    def diff_stat_summary(self) -> str:
        """生成与 git diff --stat 风格一致的摘要行。"""
        summary = (
            f"[{self.commit}] {self.from_version.value} → {self.to_version.value}: "
            f"{self.files_changed} files changed, "
            f"{self.insertions} insertions(+), "
            f"{self.deletions} deletions(-)"
        )
        _dbg("CudaVersionMigration.diff_stat_summary", f"→ {summary!r}")
        return summary

    def __str__(self) -> str:
        return self.diff_stat_summary()


