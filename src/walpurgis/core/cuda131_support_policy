@dataclass(frozen=True)
class EnvMatrixKey:
    """
    conda 环境矩阵的单个坐标（CUDA 版本 × CPU 架构）。

    对应上游文件名格式: all_cuda-131_arch-x86_64.yaml
    """
    cuda_version: CudaMinorVersion
    cpu_arch: CpuArch

    @property
    def yaml_filename(self) -> str:
        """
        生成对应的 conda 环境 YAML 文件名。

        上游命名规则: all_cuda-{cuda_label_no_dot}_arch-{arch}.yaml
          例: all_cuda-131_arch-x86_64.yaml
        """
