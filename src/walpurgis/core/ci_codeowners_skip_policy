# ── 枚举：跳过原因 ───────────────────────────────────────────────────────────

class SkipReason(Enum):
    """区分 CI 被豁免跳过的根本原因。

    上游 2ef9dba 的跳过原因属于 CONFIG_ONLY_CHANGE：CODEOWNERS 是 reviewer 配置，
    不含任何可编译/可测试代码，其变更对构建和测试结果零影响。
    Walpurgis 额外保留了 DOC_ONLY_CHANGE / INFRA_ONLY_CHANGE 两个扩展值，
    对应上游 pr.yaml 中已有的 `!CONTRIBUTING.md`/`!README.md` 等豁免条目——
    这些条目在本次提交之前就存在，本次提交是向同一机制追加了 CODEOWNERS。
    """
    CONFIG_ONLY_CHANGE = "config_only"
    DOC_ONLY_CHANGE = "doc_only"
    INFRA_ONLY_CHANGE = "infra_only"

    def human_description(self) -> str:
        """返回适合日志输出的中文说明。"""
        _map = {
            SkipReason.CONFIG_ONLY_CHANGE: "纯配置变更（reviewer/CODEOWNERS），无可测试代码",
            SkipReason.DOC_ONLY_CHANGE: "纯文档变更（README/CONTRIBUTING），无可测试代码",
            SkipReason.INFRA_ONLY_CHANGE: "纯基础设施变更（CI 脚本/版本更新），与产品代码解耦",
        }
        return _map[self]

    def blocks_code_execution(self) -> bool:
        """返回该类变更是否可能影响代码执行结果（影响则不应跳过 CI）。"""
        return False  # 所有豁免原因均为「不影响代码执行」类


