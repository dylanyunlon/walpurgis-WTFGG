# ── 模块级自检 ───────────────────────────────────────────────────────────────

def _self_test() -> None:
    """模块加载后执行基本断言，验证豁免规则结构完整性与判定逻辑正确性。

    WALPURGIS_DEBUG=1 环境下，每个断言步骤均有 _dbg 输出，
    可用于端到端验证迁移是否正确挂载到 Walpurgis 模块系统。
    """
    _dbg("SELF_TEST", "开始执行模块自检 (10 项)")

    manifest = CiSkipManifest()
    report = CiSkipAuditReport(manifest=manifest)

    # 1. 总规则数
    assert report.total_rules >= 5, f"期望 ≥5 条规则，实际 {report.total_rules}"
    _dbg("SELF_TEST", f"[1/10] 总规则数: {report.total_rules} ✓")

    # 2. 2ef9dba 引入规则数
    assert report.rules_from_2ef9dba == 1, f"期望 2ef9dba 引入 1 条规则，实际 {report.rules_from_2ef9dba}"
    _dbg("SELF_TEST", f"[2/10] 2ef9dba 引入规则: {report.rules_from_2ef9dba} ✓")

    # 3. CONFIG_ONLY 类规则至少有 1 条
    assert report.config_only_rules >= 1, f"期望 ≥1 条 CONFIG_ONLY 规则，实际 {report.config_only_rules}"
    _dbg("SELF_TEST", f"[3/10] CONFIG_ONLY 规则数: {report.config_only_rules} ✓")

    # 4. CODEOWNERS 变更集 → 全部流水线可跳过
    codeowners_only = {".github/CODEOWNERS"}
    for pipeline in CiPipelineKind:
        decision = manifest.can_skip_pipeline(pipeline, codeowners_only)
        assert decision is not None, f"流水线 {pipeline.value} 应可跳过 CODEOWNERS-only PR"
        assert decision.can_skip
        _dbg("SELF_TEST", f"[4/10] {pipeline.value} 跳过 CODEOWNERS-only: ✓")

    # 5. 有代码变更 → 不可跳过
    code_change = {".github/CODEOWNERS", "src/walpurgis/core/training.py"}
    decision = manifest.can_skip_pipeline(CiPipelineKind.PYTHON, code_change)
    assert decision is None, "含代码变更的 PR 不应跳过 PYTHON 流水线"
    _dbg("SELF_TEST", "[5/10] 代码变更 PR 不跳过 PYTHON 流水线: ✓")

    # 6. README-only → 可跳过 CPP
    readme_only = {"README.md"}
