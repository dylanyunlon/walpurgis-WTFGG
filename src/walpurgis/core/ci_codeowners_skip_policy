# ── 主清单：CI 豁免规则注册表 ────────────────────────────────────────────────

class CiSkipManifest:
    """汇总上游 pr.yaml paths-filter 中全部豁免规则。

    上游 pr.yaml 在 2ef9dba 之前已有若干豁免条目（CONTRIBUTING.md / README.md /
    ci/release/update-version.sh / *.ipynb 等），本次提交追加了
    `.github/CODEOWNERS`。

    Walpurgis 将所有已知豁免条目统一注册在此清单，
    提供「给定变更文件集合能否跳过指定 CI 流水线」的判定接口。
    这比直接阅读 pr.yaml 更可靠：YAML 中的三个重复块容易产生不一致，
    而此清单以单点定义（Single Source of Truth）替代三份拷贝。
    """

    _RULES: Tuple[PathExemptionRule, ...] = (
        # ── 2ef9dba 新增：CODEOWNERS 变更跳过全部 CI ─────────────────────
        PathExemptionRule(
            glob_pattern=".github/CODEOWNERS",
            applicable_pipelines=_ALL_PIPELINES,
            skip_reason=SkipReason.CONFIG_ONLY_CHANGE,
            introduced_by="2ef9dba",
            note=(
                "2ef9dba 核心改动：CODEOWNERS-only PR 不触发 cpp/notebooks/python 三条流水线；"
                "同时本 commit 删除了 cugraph-dgl 的 CODEOWNERS 条目（模块已废弃）"
            ),
        ),
        # ── 已有豁免：纯文档变更 ─────────────────────────────────────────
        PathExemptionRule(
            glob_pattern="CONTRIBUTING.md",
            applicable_pipelines=_ALL_PIPELINES,
            skip_reason=SkipReason.DOC_ONLY_CHANGE,
            introduced_by="pre-2ef9dba",
            note="贡献指南变更，对构建/测试零影响",
        ),
        PathExemptionRule(
            glob_pattern="README.md",
            applicable_pipelines=_ALL_PIPELINES,
            skip_reason=SkipReason.DOC_ONLY_CHANGE,
            introduced_by="pre-2ef9dba",
            note="主 README 变更，对构建/测试零影响",
        ),
        # ── 已有豁免：CI 基础设施脚本 ────────────────────────────────────
        PathExemptionRule(
            glob_pattern="ci/release/update-version.sh",
            applicable_pipelines=_ALL_PIPELINES,
            skip_reason=SkipReason.INFRA_ONLY_CHANGE,
            introduced_by="pre-2ef9dba",
            note="版本更新脚本，仅在 release 流程中运行，不影响 PR CI",
        ),
        # ── 已有豁免：.devcontainer（仅部分流水线）─────────────────────
        PathExemptionRule(
            glob_pattern=".devcontainer/**",
            applicable_pipelines=_ALL_PIPELINES,
            skip_reason=SkipReason.INFRA_ONLY_CHANGE,
            introduced_by="pre-2ef9dba",
            note="开发容器配置，不影响产品代码测试",
        ),
    )

    def __init__(self) -> None:
        _dbg("MANIFEST_INIT", f"CiSkipManifest 初始化，共 {len(self._RULES)} 条规则")
        self._by_commit: dict[str, List[PathExemptionRule]] = {}
        for rule in self._RULES:
            self._by_commit.setdefault(rule.introduced_by, []).append(rule)
        _dbg("MANIFEST_COMMIT_INDEX", f"按 commit 索引构建完成，commits={list(self._by_commit.keys())}")

    def all_rules(self) -> List[PathExemptionRule]:
        """返回全部豁免规则列表（按 glob_pattern 字典序排序）。"""
        return sorted(self._RULES, key=lambda r: r.glob_pattern)

    def rules_by_commit(self, commit_hash: str) -> List[PathExemptionRule]:
        """返回指定 commit 引入的豁免规则列表。"""
        result = self._by_commit.get(commit_hash, [])
        _dbg("MANIFEST_BY_COMMIT", f"rules_by_commit({commit_hash!r}) → {len(result)} 条规则")
        return result

    def can_skip_pipeline(
        self, pipeline: CiPipelineKind, changed_paths: Set[str]
    ) -> Optional["CiSkipDecision"]:
        """判断给定变更文件集合是否允许跳过指定流水线。

        返回 CiSkipDecision（可跳过 + 原因）或 None（不可跳过）。
        跳过条件：changed_paths 中每个路径都被至少一条适用于该流水线的豁免规则覆盖。

        上游 YAML paths-filter 的 `!pattern` 语义即：
          整个变更集合均在豁免名单内 → 跳过该流水线。
        """
        _dbg(
            "SKIP_CHECK",
            f"can_skip_pipeline({pipeline.value}, paths={changed_paths})",
        )
        applicable_rules = [r for r in self._RULES if r.covers_pipeline(pipeline)]

        uncovered: Set[str] = set()
        matched_rules: List[PathExemptionRule] = []

        for path in changed_paths:
            covering = [r for r in applicable_rules if r.matches_path(path)]
            if not covering:
                uncovered.add(path)
            else:
                matched_rules.extend(covering)

        if uncovered:
            _dbg(
                "SKIP_CHECK",
                f"流水线 {pipeline.value} 不可跳过，未被覆盖路径: {uncovered}",
            )
            return None

        decision = CiSkipDecision(
            pipeline=pipeline,
            changed_paths=frozenset(changed_paths),
            matched_rules=tuple(dict.fromkeys(matched_rules)),  # 去重保序
            can_skip=True,
        )
        _dbg(
            "SKIP_CHECK",
            f"流水线 {pipeline.value} 可跳过，命中规则数={len(decision.matched_rules)}",
        )
        return decision

    def audit_report(self) -> str:
        """生成全清单审计报告，格式对应上游 pr.yaml paths-filter 注释风格。"""
        _dbg("MANIFEST_AUDIT", "开始生成审计报告")
        lines = [
            "# CiSkipManifest 审计报告",
            "# 迁移自 rapidsai/cugraph-gnn commit 2ef9dba (#264)",
            "# Walpurgis 无 GitHub Actions pr.yaml，本报告为结构化替代品",
            "#",
            f"# 共 {len(self._RULES)} 条豁免规则，覆盖流水线: "
            + ", ".join(p.value for p in CiPipelineKind),
            "#",
        ]
        for rule in self.all_rules():
            lines.append(rule.audit_line())
            if rule.note:
                lines.append(f"#   注：{rule.note}")
        _dbg("MANIFEST_AUDIT", f"审计报告生成完毕，共 {len(lines)} 行")
        return "\n".join(lines)


_dbg("CLASS_INIT", "CiSkipManifest 类定义完成")


# ── dataclass：CI 跳过决策记录 ──────────────────────────────────────────────

@dataclass(frozen=True)
class CiSkipDecision:
    """封装「给定变更集合是否可跳过指定 CI 流水线」的决策结果。

    上游 pr.yaml 的 paths-filter 是隐式的：YAML runner 内部判定，
    开发者只能通过观察 CI 是否触发来倒推豁免是否生效。
    Walpurgis 将决策过程显式化为此结构体，每次判定均产生可审计的记录。
    """
    pipeline: CiPipelineKind
    changed_paths: FrozenSet[str]
    matched_rules: Tuple[PathExemptionRule, ...]
    can_skip: bool

    def summary(self) -> str:
        """返回单行决策摘要，适合嵌入日志或迁移记录。"""
        status = "可跳过 ✓" if self.can_skip else "不可跳过 ✗"
        rules_summary = ", ".join(f"!{r.glob_pattern}" for r in self.matched_rules)
        return (
            f"[{self.pipeline.value}] {status} | "
            f"变更路径数={len(self.changed_paths)} | "
            f"命中规则=[{rules_summary}]"
        )

    def primary_skip_reason(self) -> Optional[SkipReason]:
        """返回触发跳过的首要原因（取第一条命中规则的原因）。"""
        if not self.matched_rules:
            return None
        return self.matched_rules[0].skip_reason


# ── dataclass：豁免规则审计报告 ──────────────────────────────────────────────

@dataclass
class CiSkipAuditReport:
    """结构化输出 CI 豁免规则审计，附带 2ef9dba 迁移注释。

    2ef9dba 的核心贡献是双重的：
      1. 清理死亡模块（cugraph-dgl）的 CODEOWNERS 残留——如同清扫鲁迅《药》里
         「人血馒头」旁遗留的无主纸钱，那条目名义上还挂着所有者，实则无人认领；
      2. 对「仅更新 reviewer 名单」的 PR 豁免全量 CI——如同《故乡》里的润土，
         承认眼前这片土地（这次 PR）并不需要重新犁一遍才能证明它没有变。
    """
    manifest: CiSkipManifest
    total_rules: int = field(init=False)
    rules_from_2ef9dba: int = field(init=False)
    config_only_rules: int = field(init=False)

    def __post_init__(self) -> None:
        self.total_rules = len(self.manifest.all_rules())
        self.rules_from_2ef9dba = len(self.manifest.rules_by_commit("2ef9dba"))
        self.config_only_rules = sum(
            1 for r in self.manifest.all_rules()
            if r.skip_reason == SkipReason.CONFIG_ONLY_CHANGE
        )
        _dbg(
            "AUDIT_REPORT_INIT",
            f"CiSkipAuditReport: total={self.total_rules}, "
            f"from_2ef9dba={self.rules_from_2ef9dba}, "
            f"config_only={self.config_only_rules}",
        )

    def summary(self) -> str:
        """返回单行摘要，适合嵌入 MIGRATION_LOG。"""
        return (
            f"CI 豁免规则清单: {self.total_rules} 条规则, "
            f"{self.rules_from_2ef9dba} 条由 2ef9dba 引入, "
            f"{self.config_only_rules} 条属于纯配置变更豁免"
        )


