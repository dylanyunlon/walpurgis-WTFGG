# ── 枚举：CI 流水线类型 ──────────────────────────────────────────────────────

class CiPipelineKind(Enum):
    """对应上游 pr.yaml 中三条 paths-filter 矩阵条目。

    上游 2ef9dba 同时向 test_cpp / test_notebooks / test_python 三条流水线
    的路径过滤中新增了 `!.github/CODEOWNERS`，三者处理相同但语义独立。
    Walpurgis 显式枚举这三条流水线，使「豁免哪些流水线」成为可程序化配置，
    而非散落在 YAML 文本中的三处相同注释。
    """
    CPP = "test_cpp"
    NOTEBOOKS = "test_notebooks"
    PYTHON = "test_python"

    def upstream_yaml_key(self) -> str:
        """返回上游 pr.yaml 中对应的矩阵键名。"""
        return self.value

    def is_code_pipeline(self) -> bool:
        """返回该流水线是否直接执行代码测试（区别于文档/笔记本类）。"""
        return self in (CiPipelineKind.CPP, CiPipelineKind.PYTHON)


