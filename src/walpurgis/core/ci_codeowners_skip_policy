# ── dataclass：单条路径豁免规则 ──────────────────────────────────────────────

@dataclass(frozen=True)
class PathExemptionRule:
    """封装单条路径豁免规则（对应上游 pr.yaml paths-filter 中的一行 `!...`）。

    上游 pr.yaml 的豁免条目散落在三个 YAML 块中，每个块独立列出豁免路径，
    同一路径在三条流水线中重复出现。Walpurgis 将每条规则结构化为独立记录，
    使「路径 → 豁免流水线 → 跳过原因」三元关系可程序化查询，
    而非依赖人工阅读 YAML 文件比对三个块是否一致。

    Attributes:
        glob_pattern: 路径 glob 模式（带前缀 `!` 表示排除，此处存储不带 `!` 的原始 glob）
        applicable_pipelines: 该豁免规则适用的流水线集合
        skip_reason: 触发此豁免的语义原因
        introduced_by: 引入该规则的上游 commit hash
        note: 补充说明
    """
    glob_pattern: str
    applicable_pipelines: FrozenSet[CiPipelineKind]
    skip_reason: SkipReason
    introduced_by: str
    note: str = ""

    def matches_path(self, changed_path: str) -> bool:
        """判断给定变更路径是否命中本豁免规则。

        上游 YAML 的 `!pattern` 豁免语义：若 PR 中所有变更文件均能被豁免规则覆盖，
        则对应流水线被跳过。此方法仅判断单路径是否被本规则覆盖。
        """
        result = fnmatch.fnmatch(changed_path, self.glob_pattern)
        _dbg(
            "RULE_MATCH",
            f"matches_path({changed_path!r}, pattern={self.glob_pattern!r}) → {result}",
        )
        return result

    def covers_pipeline(self, pipeline: CiPipelineKind) -> bool:
        """返回该规则是否覆盖给定流水线。"""
        return pipeline in self.applicable_pipelines

    def audit_line(self) -> str:
        """生成审计输出行，对应上游 YAML `!{glob_pattern}` 格式。"""
        pipelines_str = ", ".join(p.value for p in sorted(self.applicable_pipelines, key=lambda x: x.value))
        return (
            f"  !{self.glob_pattern}"
            f"  # pipelines=[{pipelines_str}]"
            f"  reason={self.skip_reason.value}"
            f"  introduced={self.introduced_by}"
        )


_dbg("DATACLASS_INIT", "PathExemptionRule dataclass 定义完成（frozen=True）")


